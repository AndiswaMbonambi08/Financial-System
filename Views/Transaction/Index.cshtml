@model List<Transaction>

@{
    ViewData["Title"] = "Transactions";
}

<div class="d-flex justify-content-between align-items-center mb-20">
    <h1>Transactions</h1>
    <a href="/Transaction/Create" class="btn btn-primary">Add New Transaction</a>
</div>

<div class="card mb-20">
    <div class="card-body">
        <form method="get" class="form-row">
            <div class="form-group">
                <label for="category">Filter by Category</label>
                <select name="category" id="category">
                    <option value="">All Categories</option>
                    <option value="Income">Income</option>
                    <option value="Salary">Salary</option>
                    <option value="Food & Dining">Food & Dining</option>
                    <option value="Transportation">Transportation</option>
                    <option value="Utilities">Utilities</option>
                    <option value="Shopping">Shopping</option>
                    <option value="Entertainment">Entertainment</option>
                </select>
            </div>
            <div class="form-group">
                <label>&nbsp;</label>
                <button type="submit" class="btn btn-primary">Filter</button>
            </div>
        </form>
    </div>
</div>

@if (Model != null && Model.Count > 0)
{
    <div class="card">
        <div class="card-body">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Category</th>
                        <th>Account</th>
                        <th>Amount</th>
                        <th>Type</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var transaction in Model)
                    {
                        <tr>
                            <td>@transaction.TransactionDate.ToString("dd/MM/yyyy")</td>
                            <td>@transaction.Description</td>
                            <td>@(transaction.TransactionCategory?.CategoryName ?? "-")</td>
                            <td>@(transaction.Account.Name ?? "-")</td>
                            <td class="@(transaction.TransactionType == "Income" ? "text-success" : "text-danger")">
                                <strong>R @transaction.Amount.ToString("F2")</strong>
                            </td>
                            <td>
                                <span class="badge @(transaction.TransactionType == "Income" ? "badge-success" : "badge-danger")">
                                    @transaction.TransactionType
                                </span>
                            </td>
                            <td>
                                <a href="/Transaction/Edit/@transaction.TransactionId" class="btn btn-small btn-secondary">Edit</a>
                                <a href="/Transaction/Delete/@transaction.TransactionId" class="btn btn-small btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (ViewData["TotalPages"] != null && (int)ViewData["TotalPages"] > 1)
    {
        <div class="pagination">
            @for (int i = 1; i <= (int)ViewData["TotalPages"]; i++)
            {
                <a href="?page=@i" class="@(i == (int)ViewData["CurrentPage"] ? "active" : "")">@i</a>
            }
        </div>
    }
}
else
{
    <div class="card">
        <div class="card-body text-center">
            <p>No transactions found.</p>
            <a href="/Transaction/Create" class="btn btn-primary">Create your first transaction</a>
        </div>
    </div>
}
