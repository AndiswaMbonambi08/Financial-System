@model Financial_System.Models.Account
@{
    ViewData["Title"] = "Delete Account";
}
<h1>Delete Account</h1>
<div class="card">
    <div class="card-body">
        <p>Are you sure you want to delete <strong>@Model.Name</strong>?</p>
        <form method="post" action="/Account/Delete/@Model.AccountId">
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a href="/Account" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
